# The API container reaches MySQL by the Compose service name "db".
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=fastapi_app
MYSQL_USER=fastapi_user
MYSQL_PASSWORD=fastapi_password
MYSQL_ROOT_PASSWORD=rootpassword

# Gemini API settings. The project defaults to echo mode, so the API key is optional.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
CHAT_ASSISTANT_MODE=echo
