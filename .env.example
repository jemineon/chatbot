# FastAPI app settings
APP_NAME=FastAPI Learning Project
APP_VERSION=0.1.0
DEBUG=true

# The API container reaches MySQL by service name, so the host is "mysql".
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=fastapi_app
MYSQL_USER=fastapi_user
MYSQL_PASSWORD=fastapi_password
MYSQL_ROOT_PASSWORD=rootpassword
